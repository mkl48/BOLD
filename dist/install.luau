		self:_SetState(Enums.State.Triggered, true)

		local event = _makeEvent(source, Enums.State.Triggered)
		self:_Fire(Enums.State.Triggered, event)
		task.delay(0, function() self:_SetState(Enums.State.Triggered, nil) end)
	else
