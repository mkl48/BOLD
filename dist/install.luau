		if doMarkdown and ch2 == "**" then
			local _, e, content = raw:find("^%*%*(.-)%*%*", i)
			if e and #content > 0 then
				flush(); table.insert(tokens, { type = "text", content = content, formatting = { bold = true } }); i = e + 1; continue
			end
		end

